AUTH_JWT_SECRET=replace-with-a-long-random-secret

NEXT_PUBLIC_APTOS_NETWORK=testnet
# NEXT_PUBLIC_APTOS_API_KEY=

OPTION_B_EVENT_STORE_BACKEND=upstash
OPTION_B_PROJECTION_STORE_BACKEND=upstash
OPTION_B_MEDIA_PIPELINE_MODE=manual-pending

UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token

CRON_SECRET=replace-with-a-long-random-cron-secret

SHELBY_RPC_URL=https://api.testnet.shelby.xyz/shelby
SHELBY_API_KEY=replace-with-shelby-api-key
# SHELBY_RPC_AUTH_HEADER=x-api-key
# SHELBY_RPC_WRITE_PATH=
# SHELBY_RPC_READ_PATH=
# SHELBY_COORDINATOR_URL=

ALLOW_MOCK_FALLBACK=false

# Optional internal auth for service-to-service calls
# SERVICE_AUTH_TOKEN=replace-with-service-token

# Optional wallet sign-in override
# WALLET_SIGNIN_STATEMENT=Sign in to Verra

# Optional legacy role allowlists
# ADMIN_WALLETS=0x...,0x...
# CREATOR_WALLETS=0x...,0x...

# Do not rely on relational persistence in Vercel Option B runtime
# PERSISTENCE_DRIVER=
# DATABASE_URL=
